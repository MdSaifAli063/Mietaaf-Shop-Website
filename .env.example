# Safe template only. Never commit .env or .env.local with real values.
# In Vercel, add these in Project Settings -> Environment Variables.

# Canonical production origin, for example https://mietaaf.com.
# Leave blank locally (the app falls back to http://localhost:3000).
# It may also be left blank on a Vercel Preview deployment, where VERCEL_URL is used.
NEXT_PUBLIC_SITE_URL=

# WhatsApp business number: country code + number, digits only.
NEXT_PUBLIC_WHATSAPP_NUMBER=917411025321

# Optional sitewide logo override: /path-under-public.png or a full HTTPS URL.
NEXT_PUBLIC_SITE_LOGO_URL=

# Optional footer social links.
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=

# EmailJS browser integration. Use one service and two separate templates.
# Appointment variables:
# {{to_email}}, {{subject}}, {{from_name}}, {{reply_to}}, {{phone}},
# {{customer_email}}, {{city}}, {{address}}, {{service_type}},
# {{appointment_date}}, {{appointment_time}}, {{visit_type}}, {{outfit_type}},
# {{fabrics}}, {{budget}}, {{occasion_date}}, {{notes}}, {{message}}
# Contact variables:
# {{to_email}}, {{subject}}, {{from_name}}, {{reply_to}}, {{customer_email}},
# {{phone}}, {{topic}}, {{customer_message}}, {{message}}
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_APPOINTMENT_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_CONTACT_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Firebase Web SDK configuration from Firebase Console -> Project settings.
# These identifiers are intentionally public; Firebase Rules provide security.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
